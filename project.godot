; Engine configuration file for METAZOIC.
; This is a plain-text INI-style file — safe to read and edit by hand or by AI.
; Docs: https://docs.godotengine.org/en/stable/classes/class_projectsettings.html

config_version=5

[application]

config/name="METAZOIC"
config/description="PS2-style third-person open-world game. A meteorite carries a parasite that grants powers; the caveman absorbs them by defeating boss dinosaurs."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

; Global singleton that tracks which powers the player has absorbed.
PowerSystem="*res://scripts/systems/power_system.gd"
; Blood, gibs, hit-stop — all impact FX, generated in code.
Gore="*res://scripts/systems/gore.gd"
; All sound: SFX pools, music, ambient loops (assets from tools/asset_gen/).
Sfx="*res://scripts/systems/sfx.gd"
; Blood currency, kill records, and mutation/character upgrade levels.
Stats="*res://scripts/systems/stats.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
; Launch fullscreen.
window/size/mode=3

[gui]

; Dark-fantasy serif font for all UI (SystemFont — no bundled binaries needed).
theme/custom="res://assets/ui/theme.tres"

[rendering]

textures/vram_compression/import_etc2_astc=true
; PS2 look: render the 3D scene at 45% resolution (~576x324), then upscale.
; The psx_post.gdshader dither/quantize filter stacks on top of this.
scaling_3d/scale=0.58
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=2
